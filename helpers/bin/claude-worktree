#!/usr/bin/env bash
#
# claude-worktree <branch> [dir-name]
#
# Create (or attach to) a git worktree for <branch> and open it in a NEW GHOSTTY
# TAB running `claude` — one command to spin up an isolated agent per branch.
#
# Worktrees are placed alongside the main repo following the convention:
#   <parent>/<repo>-worktrees/<dir-name>
# e.g. from ~/Repos/myrepo, branch feat/foo -> ~/Repos/myrepo-worktrees/foo
#
# <dir-name> defaults to the last path segment of <branch>.
# A brand-new branch is forked from the current HEAD.
set -euo pipefail

die() { printf 'claude-worktree: %s\n' "$1" >&2; exit "${2:-1}"; }

branch="${1:-}"
[ -n "$branch" ] || die "usage: claude-worktree <branch> [dir-name]" 2

command -v git >/dev/null || die "git not found"
git rev-parse --git-dir >/dev/null 2>&1 || die "not inside a git repository"

dir_name="${2:-$(basename "$branch")}"

# Resolve the MAIN repo (works even when run from inside another worktree) via
# the common git dir, whose parent is the primary working tree.
common_git="$(git rev-parse --path-format=absolute --git-common-dir)"
main_repo="$(dirname "$common_git")"
repo_name="$(basename "$main_repo")"
wt_dir="$(dirname "$main_repo")/${repo_name}-worktrees/${dir_name}"

if [ -d "$wt_dir" ]; then
  echo "→ reusing existing worktree dir: $wt_dir"
else
  mkdir -p "$(dirname "$wt_dir")"
  if git show-ref --verify --quiet "refs/heads/$branch"; then
    echo "→ checking out existing local branch '$branch'"
    git worktree add "$wt_dir" "$branch"
  elif git ls-remote --exit-code --heads origin "$branch" >/dev/null 2>&1; then
    echo "→ tracking remote branch 'origin/$branch'"
    git fetch -q origin "$branch"
    git worktree add "$wt_dir" -b "$branch" --track "origin/$branch"
  else
    echo "→ creating new branch '$branch' from $(git rev-parse --abbrev-ref HEAD)"
    git worktree add "$wt_dir" -b "$branch"
  fi
fi

# Open the worktree in a new Ghostty tab and start claude. Ghostty has no CLI to
# open a tab on macOS, so we drive the app: focus it, send the new-tab keystroke,
# then type the command. (First run may prompt for Accessibility permission.)
# If CLAUDE_WT_PROMPT is set, launch claude with it as the opening prompt.
if [ -n "${CLAUDE_WT_PROMPT:-}" ]; then
  typed="cd $(printf '%q' "$wt_dir") && claude $(printf '%q' "$CLAUDE_WT_PROMPT")"
else
  typed="cd $(printf '%q' "$wt_dir") && claude"
fi
osascript - "$typed" >/dev/null <<'APPLESCRIPT'
on run argv
  set theCmd to item 1 of argv
  tell application "Ghostty" to activate
  delay 0.25
  tell application "System Events"
    keystroke "t" using {command down}
    delay 0.45
    keystroke theCmd
    key code 36
  end tell
end run
APPLESCRIPT

echo "→ opened new Ghostty tab in $wt_dir running claude"
